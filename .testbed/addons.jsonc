{
  "$schema": "https://chickensoft.games/schemas/addons.schema.json",
  "addons": {
    // Mount the current repo package from the repo root so the hidden testbed stages the installed addon path deterministically.
    "aerobeat-spatial-ui-touch": {
      "url": "..",
      "source": "symlink",
      "subfolder": "/"
    },
    // Canonical shared UI interaction contract for all AeroBeat spatial UI providers.
    "aerobeat-input-core": {
      "url": "git@github.com:AeroBeat-Workouts/aerobeat-input-core.git",
      "checkout": "main",
      "subfolder": "/"
    },
    // Shared helper-layer package for spatial UI provider infrastructure.
    "aerobeat-spatial-ui-core": {
      "url": "git@github.com:AeroBeat-Workouts/aerobeat-spatial-ui-core.git",
      "checkout": "main",
      "subfolder": "/"
    },
    // GUT drives the repo-local test suite inside the hidden testbed/workbench.
    "gut": {
      "url": "git@github.com:bitwes/Gut.git",
      "checkout": "main",
      "subfolder": "/addons/gut"
    }
  }
}
